rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny-all. Server writes/reads happen through Firebase Admin SDK.
    match /{document=**} {
      allow read, write: if false;
    }

    // If you later enable client-side Firestore for this collection, this is the
    // strict minimum owner-only policy. Keep disabled for now by deny-all above.
    match /siteforgeUsers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
